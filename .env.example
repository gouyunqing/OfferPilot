# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/offerpilot

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_DAYS=30

# WeChat
WECHAT_APP_ID=your_wechat_app_id
WECHAT_APP_SECRET=your_wechat_app_secret

# SMS (Aliyun)
ALIYUN_ACCESS_KEY_ID=your_key_id
ALIYUN_ACCESS_KEY_SECRET=your_key_secret
ALIYUN_SMS_SIGN_NAME=OfferPilot
ALIYUN_SMS_TEMPLATE_CODE=SMS_xxx

# AI
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Apple IAP
APPLE_BUNDLE_ID=com.offerpilot.app
APPLE_SHARED_SECRET=your_apple_shared_secret

# App
DEBUG=true
CORS_ORIGINS=["http://localhost:3000"]
